# Replace with your real domain before deployment, e.g. example.com
{$SERVICE_DOMAIN:localhost} {
  # Persisted via docker-compose: ./logs/caddy -> /var/log/caddy
  log {
    output file /var/log/caddy/access.log {
      roll_size 10mb
      roll_keep 14
    }
    format json
  }

  encode gzip zstd

  # Optional hardening headers
  header {
    -Server
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    # Next.js requires inline styles/scripts for framework hydration.
    Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: wss:;"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }

  handle /api/health {
    uri replace /api/health /health
    reverse_proxy backend:8080
  }

  @api path /api/*
  handle @api {
    reverse_proxy backend:8080
  }

  handle {
    reverse_proxy frontend:3000
  }
}
